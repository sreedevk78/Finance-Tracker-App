rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // User Profile
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
        incoming().diff(existing()).affectedKeys().hasOnly(['fullName', 'monthlyIncome', 'currency', 'financialPersona', 'riskTolerance', 'updatedAt']);
      
      function isValidUser(data) {
        return data.email is string && data.email.size() > 0 &&
               data.createdAt is timestamp;
      }

      // Transactions
      match /transactions/{transactionId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidTransaction(incoming());
        allow update: if isOwner(userId) && isValidTransaction(incoming()) &&
          incoming().diff(existing()).affectedKeys().hasOnly(['amount', 'merchantName', 'description', 'categoryId', 'date', 'isRecurring', 'emotionTag', 'source']);
        allow delete: if isOwner(userId);

        function isValidTransaction(data) {
          return data.userId == request.auth.uid &&
                 data.amount is number &&
                 data.type in ['debit', 'credit', 'transfer'] &&
                 data.date is timestamp;
        }
      }

      // Goals
      match /goals/{goalId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidGoal(incoming());
        allow update: if isOwner(userId) && isValidGoal(incoming());
        allow delete: if isOwner(userId);

        function isValidGoal(data) {
          return data.userId == request.auth.uid &&
                 data.title is string && data.title.size() > 0 &&
                 data.targetAmount is number;
        }
      }

      // Insights
      match /insights/{insightId} {
        allow list, get: if isOwner(userId);
        allow create, update: if false; // Only system should create/update via Admin SDK or Edge Functions (simulated via AI server)
        allow update: if isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['isRead']);
      }

      // Subscriptions
      match /subscriptions/{subscriptionId} {
        allow list, get: if isOwner(userId);
        allow create, update, delete: if isOwner(userId);
      }
    }
  }
}
